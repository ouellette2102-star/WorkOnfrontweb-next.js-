# WorkOn Frontend - Environment Variables
# Copy this file to .env.local and fill in the values
# NEVER commit .env.local to git

# ============================================
# BACKEND API (REQUIRED)
# ============================================
# Full backend base URL INCLUDING the /api/v1 prefix.
# WARNING: omitting /api/v1 will silently break every backend call (404).
#
# Local dev (NestJS on port 3001):
#   NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
# Production (Railway):
#   NEXT_PUBLIC_API_URL=https://workon-backend-production-8908.up.railway.app/api/v1

NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# ============================================
# APP CONFIGURATION (OPTIONAL)
# ============================================

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# STRIPE PAYMENTS (OPTIONAL)
# ============================================

# STRIPE_SECRET_KEY=sk_test_your_key_here
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# ============================================
# MAPBOX (OPTIONAL)
# ============================================

# NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_token_here

# ============================================
# FIREBASE CLOUD MESSAGING — Web push (OPTIONAL)
# ============================================
# Browser push (`new_message`, `swipe_match`, `lead_delivered`, etc.)
# requires the Firebase Web SDK + a VAPID key. All five values are
# public — they're embedded in the client bundle. The private side
# is the Admin SDK on the backend (FIREBASE_PRIVATE_KEY).
#
# Set these in Vercel project settings, then redeploy. When unset,
# the FE falls back gracefully to in-app-only notifications.

# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=workon-xxxx.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=workon-xxxx
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=1:xxx:web:xxx
# NEXT_PUBLIC_FIREBASE_VAPID_KEY=BGxxx... (Firebase Console > Cloud Messaging > Web Push certificates)
